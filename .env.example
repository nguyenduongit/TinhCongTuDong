DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Dùng cho Frontend gọi lên Google
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"

# Dùng cho Backend xác thực token của Google
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"

# Chuỗi bí mật ngẫu nhiên dùng để tạo phiên đăng nhập (JWT)
# Tạo bằng lệnh: openssl rand -base64 32
JWT_SECRET="YOUR_SECURE_RANDOM_JWT_SECRET"

# Allowed origins cho CORS
ALLOWED_ORIGINS="http://localhost:5173"
